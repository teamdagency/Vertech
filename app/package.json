{
  "name": "@vertech/api",
  "version": "0.1.0",
  "private": true,
  "description": "API monolithe modulaire Vertech (Identity, Profiles, Skills, Projects, Community, Trust & Reputation, Search, Notifications, Moderation)",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "drizzle:pull": "drizzle-kit pull --config=drizzle.config.ts",
    "drizzle:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
